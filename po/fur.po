#: data/net.reactivated.fprint.device.policy.in:13
msgid "Verify a fingerprint"
msgstr "Verifiche un impront digjitâl"

#: data/net.reactivated.fprint.device.policy.in:14
msgid "Privileges are required to verify fingerprints."
msgstr "A son necessaris i privileçs par verificâ impronts digjitâi."

#: data/net.reactivated.fprint.device.policy.in:23
msgid "Enroll or Delete fingerprints"
msgstr "Regjistre o elimine impronts digjitâi"

#: data/net.reactivated.fprint.device.policy.in:24
msgid "Privileges are required to enroll or delete fingerprints."
msgstr ""
"I privileçs a son necessaris par regjistrâ o eliminâ impronts digjitâi."

#: data/net.reactivated.fprint.device.policy.in:33
msgid "Select a user to manage fingerprints for"
msgstr "Selezione un utent par podê gjestî i siei impronts digjitâi"

#: data/net.reactivated.fprint.device.policy.in:34
msgid "Privileges are required to manage fingerprints for other users."
msgstr ""
"I privileçs a son necessaris par gjestî i impronts digjitâi par altris "
"utents."

#: src/device.c:799
#, c-format
msgid "Device was not claimed before use"
msgstr "Il dispositîf nol è stât rivendicât prime jessi doprât"

#: src/device.c:808
#, c-format
msgid "Device already in use by another user"
msgstr "Il dispositîf al è za doprât di un altri utent"

